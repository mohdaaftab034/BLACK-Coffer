# Server port (must match frontend VITE_API_BASE_URL port)
PORT=4000

# MongoDB connection string (local or Atlas)
# For local: mongodb://localhost:27017/blackcoffer_dashboard
# For Atlas: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/blackcoffer_dashboard
MONGODB_URI=mongodb://localhost:27017/blackcoffer_dashboard

# Node environment
NODE_ENV=development

# Allowed CORS origin (your frontend URL)
CORS_ORIGIN=http://localhost:5173
